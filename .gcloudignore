.gcloudignore
.git/
.gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-*/
.uv/
build/
dist/
.pytest_cache/
.ruff_cache/

# Data (large, not needed in the build context images)
data/raw/*
data/external/*
!data/raw/.gitkeep
!data/external/.gitkeep

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*

# dbt
dbt/retail_demand/target/
dbt/retail_demand/dbt_packages/
dbt/retail_demand/logs/

# Notebooks
.ipynb_checkpoints/

# Local training outputs
artifacts/

# Frontend (not needed for the Python-based pipeline/serving images)
frontend/node_modules/
frontend/.next/

# OS / editor
.DS_Store
.idea/
*.log
