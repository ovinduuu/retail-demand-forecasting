# Copy to .env.local for local dev. Never commit the real .env.local.

# Base URL of the serving API (src/retail_demand/serving/app.py).
# Defaults to http://localhost:8080 if unset - see the root README.md for
# how to run that locally, or ../docker/serving.Dockerfile /
# ../infra/terraform for the real deployed Cloud Run URL once it exists.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
