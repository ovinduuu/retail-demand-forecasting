# Copy to .env and fill in. Never commit the real .env.

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_RAW_BUCKET=your-gcp-project-id-retail-demand-raw
BQ_DATASET_RAW=retail_demand_raw
BQ_DATASET_STAGING=retail_demand_staging
BQ_DATASET_MARTS=retail_demand_marts

# Kaggle (for src/retail_demand/data_engineering/download_m5.py)
# Get from https://www.kaggle.com/settings -> API -> Create New Token,
# which downloads kaggle.json. Either place it at ~/.kaggle/kaggle.json
# or set the two vars below.
KAGGLE_USERNAME=
KAGGLE_KEY=
